completely_remove() {
    sudo apt-get remove --auto-remove --purge $1
    sudo apt-get clean
    sudo apt-get autoremove -y
}

tmux_auto_attach() {
    first_session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | head -n 1)
    if [ -n "$first_session" ]; then
        tmux attach-session -t "$first_session"
    else
        tmux new-session -s default-session
    fi
}

pythonvenv() {
    python3 -m venv .venv
    source .venv/bin/activate
    pip install --upgrade pip
}

