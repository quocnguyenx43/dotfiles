# Remove packages
completely_remove() {
    sudo apt-get remove --auto-remove --purge $1
    sudo apt-get clean
    sudo apt-get autoremove -y
}

# Python
pythonvenv() {
    python3 -m venv .venv
    source .venv/bin/activate
    proxychains pip install --upgrade pip
}

